# Copy this file to ".env" and fill in your key.

# Required: your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Optional: override the model. Defaults to Claude Sonnet 4.6.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Optional: used by OpenRouter for ranking/attribution.
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_TITLE=XML Agent

# Optional: prompt caching (Anthropic models). Default on.
#   OPENROUTER_CACHE=false       disables cache_control markers
#   OPENROUTER_CACHE_TTL=1h      use 1-hour TTL (default 5m) for long sessions
OPENROUTER_CACHE=true
OPENROUTER_CACHE_TTL=5m

# Optional: extended thinking. Unset = off. Values:
#   xhigh | high | medium | low | minimal | none
# OPENROUTER_REASONING_EFFORT=medium

# Optional: sampling temperature. 0 (default) = deterministic XML output.
OPENROUTER_TEMPERATURE=0
