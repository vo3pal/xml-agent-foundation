{
  "name": "xml-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "An autonomous AI coding agent that uses XML-formatted tool calling (client-side fallback style) on top of the OpenRouter SDK with Claude Sonnet.",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--use-system-ca tsx src/index.ts",
    "start": "cross-env NODE_OPTIONS=--use-system-ca tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test:parser": "tsx src/xml/parser.smoke.ts",
    "ping": "cross-env NODE_OPTIONS=--use-system-ca tsx src/dev/ping.ts",
    "diag": "cross-env NODE_OPTIONS=--use-system-ca tsx src/dev/diag.ts"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.12.35",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
